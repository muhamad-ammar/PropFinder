# ==========================================
# Dependency Managers
# ==========================================

# Swift Package Manager (SPM)
# Ignore build artifacts but keep the package layout configurations
.build/
.swiftpm/
# Un-comment the next line if you want to cache the exact dependency clones locally
# .swiftpm/xcode/package.resolved

# CocoaPods
# Ignore the Pods directory unless you intentionally want to check it in
Pods/
*.xcworkspace

# Carthage
Carthage/Build/

